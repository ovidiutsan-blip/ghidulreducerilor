# === GhidulReducerilor.ro — Variabile de Mediu ===

# Profitshare.ro — ID-ul tău de afiliat
# Îl găsești în dashboard-ul Profitshare > Setări cont
NEXT_PUBLIC_PROFITSHARE_AFFILIATE_ID=YOUR_PROFITSHARE_ID

# Profitshare API (pentru agenții Python de actualizare automată)
PROFITSHARE_API_KEY=your_api_key_here
PROFITSHARE_AFFILIATE_ID=your_affiliate_id_here

# Profitshare Campaign IDs (per magazin — din dashboard Profitshare)
PS_EMAG_ID=
PS_FASHIONDAYS_ID=
PS_VEXIO_ID=
PS_LIBRIS_ID=
PS_FORNELLO_ID=
PS_FORIT_ID=

# Brevo (fostul Sendinblue) — API Key pentru alerte email
# Obține cheia din: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here

# Brevo — ID-ul listei de contacte pentru abonați
BREVO_LIST_ID=2

# Brevo — Email settings pentru agent alerts
BREVO_FROM_EMAIL=alerts@ghidulreducerilor.ro
BREVO_FROM_NAME=GhidulReducerilor.ro
BREVO_ALERT_TO=your_email@example.com

# Google Analytics 4 — Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# URL-ul site-ului (pentru sitemap, canonical URLs, OG tags)
NEXT_PUBLIC_SITE_URL=https://ghidulreducerilor.ro
SITE_URL=https://ghidulreducerilor.ro

# === SISTEM AUTOMAT ===

# Admin API — token secret pentru /api/admin/*
# Generează cu: openssl rand -hex 32
ADMIN_SECRET_TOKEN=your-secret-admin-token-here

# Vercel Cron Secret — verificare autenticitate cron jobs
# Setat automat de Vercel sau manual dacă testezi local
CRON_SECRET=your-cron-secret-here

# Social Media — Facebook Graph API
# Obține din: https://developers.facebook.com/apps/
FB_PAGE_ID=your_page_id
FB_ACCESS_TOKEN=your_page_access_token

# Social Media — Instagram Business
# Același app ca Facebook, necesită IG Business Account conectat
IG_USER_ID=your_ig_user_id
IG_ACCESS_TOKEN=your_ig_access_token

# Email Suport
REPORT_EMAIL=hello@ghidulreducerilor.ro
BREVO_INBOX_ID=your_brevo_inbox_id

# 2Performant (când aplici la magazine noi)
# ID-ul tău: d8b71657a
TWOPERFORMANT_API_KEY=your_2p_api_key
TWOPERFORMANT_AFFILIATE_ID=d8b71657a
